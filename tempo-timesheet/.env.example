# Tempo Timesheet API credentials
# Get TEMPO_TOKEN from: Tempo -> Settings -> Data Access -> API Integration -> New Token
# Get TEMPO_ACCOUNT_ID from: Atlassian Profile page URL, format: https://home.atlassian.com/o/<org-id>/people/<account-id>?cloudId=...
# The account ID looks like: 712020:xxxx-xxxx-xxxx-xxxx (URL-encoded as 712020%3Axxxx-xxxx-xxxx-xxxx, replace %3A with :)
TEMPO_TOKEN=
TEMPO_ACCOUNT_ID=
